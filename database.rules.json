{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "sessions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "leaderboards": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
